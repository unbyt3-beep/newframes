	display:none !important;
}
.rich-header.version1 .rh-content .nz-breadcrumbs {
    float: none;
}
.headr-dgn::before {
    -webkit-box-sizing: content-box;
    -moz-box-sizing: content-box;
    box-sizing: content-box;
    width: 30.1%;
    height: 69px;
    position: absolute;
    content: "";
    bottom: -49px;
    left: 0;
    border: none;
    -o-text-overflow: clip;
    text-overflow: clip;
    background: #fff;
    text-shadow: none;
    -webkit-transform: skewY(2.4deg);
    transform: skewY(2.4deg);
    -ms-transform: skewY(2.4deg);
    z-index: 9;
}
.headr-dgn::after{
    -webkit-box-sizing: content-box;
    -moz-box-sizing: content-box;
    box-sizing: content-box;
    width: 70.1%;
    height: 67px;
    position: absolute;
    content: "";
    bottom: -31px;
    right: 0;
    border: none;
    -o-text-overflow: clip;
    text-overflow: clip;
    background: #fff;
    text-shadow: none;
    -webkit-transform: skewY(-2.4deg);
    transform: skewY(-2.4deg);
    -ms-transform: skewY(-2.4deg);
    z-index: 9;
}
.headr-dgn{
    z-index: 99;
    position: relative;
    width: 100%;
}
.footer-dgn::before {
    -webkit-box-sizing: content-box;
    -moz-box-sizing: content-box;
    box-sizing: content-box;
    width: 70.1%;
    height: 69px;
    position: absolute;
    content: "";
    bottom: -33px;
    left: 0;
    border: none;
    -o-text-overflow: clip;
    text-overflow: clip;
    background: #cad9ff;
    text-shadow: none;
    -webkit-transform: skewY(-2.4deg);
    transform: skewY(-2.4deg);
    -ms-transform: skewY(-2.4deg);
    z-index: 9;
}
.footer-dgn::after{
    -webkit-box-sizing: content-box;
    -moz-box-sizing: content-box;
    box-sizing: content-box;
    width: 30.1%;
    height: 67px;
    position: absolute;
    content: "";
    bottom: -17px;
    right: 0;
    border: none;
    -o-text-overflow: clip;
    text-overflow: clip;
    background:#cad9ff;
    text-shadow: none;
    -webkit-transform: skewY(2.4deg);
    transform: skewY(2.4deg);
    -ms-transform: skewY(2.4deg);
    z-index: 9;
}
.footer-dgn{
    z-index: 99;
    position: relative;
    width: 100%;
}
